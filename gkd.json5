{
  id: 888,
  name: '黎雄克自用订阅',
  version: 2,  // 每次修改记得 +1
  author: '黎雄克',
  categories: [
    { key: 1, name: '开屏广告' },
    { key: 2, name: '信息流广告' }
  ],
  apps: [
    // 1. 酷安信息流广告规则（你原来的）
    {
      id: 'com.coolapk.market',
      name: '酷安',
      groups: [
        {
          key: 1,
          name: '信息流广告（ad_container）',
          category: 2,
          activityIds: 'com.coolapk.market.view.main.MainActivity',
          rules: [
            {
              matches: '@TextView <3 FrameLayout < FrameLayout < [vid="ad_container"]',
              action: 'click'
            }
          ]
        }
      ]
    },
    // 2. 新增：通用开屏广告规则（用于测试GKD是否工作）
    {
      id: 'com.ss.android.ugc.aweme', // 抖音，用来测试
      name: '抖音',
      groups: [
        {
          key: 1,
          name: '开屏广告-跳过',
          category: 1,
          rules: [
            {
              matches: '[text*="跳过"][clickable=true]',
              action: 'click',
              delay: 1500 // 延迟1.5秒点，防止误触
            }
          ]
        }
      ]
    }
  ]
}
